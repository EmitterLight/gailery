# Gailery environment configuration
# Copy this file to .env and adjust values for your setup

# Photo directory (required: path to your photo collection)
PHOTO_SHARE_PATH=/photos

# Data directory (SQLite DB, LanceDB, pipeline flags)
GALLERY_DATA_DIR=./data

# Thumbnails directory
GALLERY_THUMBNAILS_DIR=./thumbnails

# Logs directory
GALLERY_LOGS_DIR=./logs

# llama.cpp installation directory
LLAMA_CPP_DIR=/usr/local

# Python venv executable
GALLERY_VENV_PYTHON=./venv/bin/python3
